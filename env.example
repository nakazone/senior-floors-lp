# Database (MySQL - NÃO usar em SYSTEM_API_URL)
# Ex.: mysql-production-d0e8.up.railway.app é só o banco; o form usa a API (ver abaixo).
DB_HOST=mysql.railway.internal
DB_NAME=railway
DB_USER=root
DB_PASS=your_password

# API do sistema no Railway - OBRIGATÓRIO para o form da LP salvar leads no Railway.
# URL do serviço Node (não use o host MySQL).
SYSTEM_API_URL=https://senior-floors-system-production.up.railway.app

# Server (Railway sets PORT)
PORT=3306

# Session secret (required for authentication)
SESSION_SECRET=75febefd659f0eb64fd933375a975215a30e41e0290e50db0d81de97d5e1f502

# Opcional: segredo para sync Google Sheets → POST /api/receive-lead (Apps Script envia
# headers X-Sheets-Sync: 1 e X-Sheets-Sync-Secret). A LP na Vercel não precisa disso.
# SHEETS_SYNC_SECRET=um_segredo_longo_aleatorio

# Opcional: notificação no celular (app ntfy) quando um lead NOVO entra no CRM.
# No telefone: instale ntfy e inscreva-se no mesmo tópico (use string longa e aleatória).
# LEAD_NTFY_TOPIC=meu_topico_secreto_longo
# LEAD_NTFY_URL=https://ntfy.sh