# Database (MySQL - NÃO usar em SYSTEM_API_URL)
# Ex.: mysql-production-d0e8.up.railway.app é só o banco; o form usa a API (ver abaixo).
DB_HOST=mysql.railway.internal
DB_NAME=railway
DB_USER=root
DB_PASS=your_password

# API do sistema no Railway - OBRIGATÓRIO para o form da LP salvar leads no Railway.
# URL do serviço Node (não use o host MySQL).
SYSTEM_API_URL=https://senior-floors-system-production.up.railway.app

# Server (Railway sets PORT)
PORT=3306

# Session secret (required for authentication)
SESSION_SECRET=75febefd659f0eb64fd933375a975215a30e41e0290e50db0d81de97d5e1f502